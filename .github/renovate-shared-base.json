{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "enabledManagers": [
    "cargo",
    "custom.regex",
    "github-actions"
  ],
  "rangeStrategy": "bump",
  "prConcurrentLimit": 0,
  "printConfig": true,
  "prHourlyLimit": 0,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "Cargo.toml",
        "**/Cargo.toml"
      ],
      "matchStrings": [
        "rust-version\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+(?:\\.\\d+)?)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "rust",
      "packageNameTemplate": "rust-lang/rust"
    }
  ],
  // Auto-merge is disable except for rules defined in packageRules.
  "automerge": false,
  "automergeType": "branch",
  "packageRules": [
    // Auto-merge rules are allows different groups of dependencies to be merged automatically.
    // Double check before changing them if the reason is redundancy or if you want to add a new rule.
    // Take into account that there are multiple managers (e.g. cargo, github-actions, etc).
    {
      "matchUpdateTypes": [
        "patch",
        "lockFileMaintenance",
        "digest",
        "pin",
        "pinDigest"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    // minor updates of stable dependencies for all managers.
    {
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": ">=1.0.0",
      "automerge": true
    },
    // Cargo minor updates
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    // Cargo minor updates exceptions.
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor"],
      "matchPackageNames": [
        "/^opentelemetry/",
        "/^tracing/",
        "reqwest",
        "prost",
        "nix",
        "oci-client",
        "crossbeam"
      ],
      "automerge": false
    },
    {
      "groupName": "github actions",
      "matchManagers": [
        "github-actions"
      ],
      "schedule": [
        "before 4am on Monday"
      ]
    },
    {
      "enabled": false,
      "matchPackageNames": [
        "/serde_yaml/"
      ]
    },
    {
      "groupName": "kubernetes crates",
      "matchManagers": [
        "cargo"
      ],
      "matchPackageNames": [
        "kube",
        "k8s",
        "schemars"
      ]
    }
  ]
}
